{
  "name": "abraxius",
  "version": "1.0.0",
  "description": "AI-ready MCP bridge, Studio companion plugin, and script sync for Roblox Studio",
  "main": "client.js",
  "bin": {
    "mcp": "./cli.js"
  },
  "scripts": {
    "start": "node server.js start",
    "stop": "node server.js stop",
    "status": "node server.js status",
    "example": "node examples/basic.js",
    "docs:dev": "moonwave dev --code .moonwave/stub",
    "docs:build": "moonwave build --fresh --code .moonwave/stub",
    "smoke": "node scripts/smoke.js",
    "rust:check": "cargo check --manifest-path rust/abraxius-rs/Cargo.toml",
    "rust:build": "cargo build --manifest-path rust/abraxius-rs/Cargo.toml",
    "rust:run": "cargo run --manifest-path rust/abraxius-rs/Cargo.toml --bin abraxius-rs --",
    "rust:daemon": "cargo run --manifest-path rust/abraxius-rs/Cargo.toml --bin abraxius-daemon",
    "install-plugin": "node scripts/install-plugin.js",
    "plugin": "node scripts/install-plugin.js"
  },
  "keywords": [
    "roblox",
    "mcp",
    "studio",
    "websocket",
    "cli",
    "sync",
    "luau",
    "ai-context",
    "roblox-studio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "moonwave": "^1.4.2"
  }
}
