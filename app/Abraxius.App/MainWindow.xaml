<Window
    x:Class="Abraxius.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Abraxius">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Abraxius" Subtitle="Roblox Studio bridge">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/Logo.png" />
            </TitleBar.IconSource>
        </TitleBar>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="820" Padding="32,24,32,32" HorizontalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <InfoBar x:Name="MessageBar" IsOpen="False" IsClosable="True" />

                <Grid Grid.Row="1" Margin="0,8,0,0" ColumnSpacing="12" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="SERVER" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse x:Name="ServerDot" Width="9" Height="9" Fill="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="ServerStatus" Text="Checking" Style="{ThemeResource SubtitleTextBlockStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ROBLOX STUDIO" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse x:Name="StudioDot" Width="9" Height="9" Fill="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="StudioStatus" Text="Checking" Style="{ThemeResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="18" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="COMPANION" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="9">
                                <Ellipse x:Name="PluginDot" Width="9" Height="9" Fill="{ThemeResource SystemFillColorCautionBrush}" VerticalAlignment="Center" />
                                <TextBlock x:Name="PluginStatus" Text="Checking" Style="{ThemeResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Margin="0,24,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailText" Text="Reading local host status..." Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <StackPanel Grid.Row="1" Margin="0,18,0,0" Orientation="Horizontal" Spacing="10">
                        <Button x:Name="StartButton" Click="StartButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock x:Name="StartButtonText" Text="Start server" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="StopButton" Click="StopButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Stop" />
                                <TextBlock Text="Stop server" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="LogsButton" Click="LogsButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Document" />
                                <TextBlock Text="Open logs" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="3" Margin="0,30,0,0" Spacing="14">
                    <TextBlock Text="Behavior" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ToggleSwitch x:Name="StartupToggle" Header="Start with Windows" Toggled="StartupToggle_Toggled" />
                    <ToggleSwitch x:Name="SupervisionToggle" Header="Keep the Rust server running" IsOn="True" Toggled="SupervisionToggle_Toggled" />
                    <TextBlock Text="Closing this window keeps Abraxius active in the notification area." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
